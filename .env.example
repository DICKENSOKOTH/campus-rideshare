# Campus Rideshare — Environment Variables
# Copy this file to .env and fill in your actual values.

# ── Flask ─────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-change-this
DEBUG=True

# ── Database ──────────────────────────────────────────────────
# Set USE_SQLITE=True for local development (no PostgreSQL needed).
# Set USE_SQLITE=False for production (uses PostgreSQL below).
USE_SQLITE=True
SQLITE_PATH=campus_rideshare.db

# PostgreSQL (only used when USE_SQLITE=False)
DB_NAME=campus_rideshare_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*

# ── OpenAI (AI Assistant) ────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
CHATBOT_RATE_LIMIT=10

# ── WebSocket ─────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=8765